# ===================================================================
#  KONFIGURACJA BOTA - wszystkie zmienne srodowiskowe
#  Skopiuj ten plik do ".env" i uzupelnij wartosci.
#    Windows:  copy .env.example .env
#    Linux/Mac: cp .env.example .env
# ===================================================================

# ============ WYMAGANE ============

# Token bota z https://discord.com/developers/applications  (zakladka Bot)
DISCORD_TOKEN=

# Polaczenie do PostgreSQL.
# Lokalnie:  postgresql://user:haslo@localhost:5432/discordbot
# Na Railway: ustawia sie automatycznie po dodaniu pluginu PostgreSQL.
DATABASE_URL=

# ============ OPCJONALNE ============

# ID serwera testowego - komendy slash pojawia sie natychmiast.
# Zostaw puste, aby zarejestrowac komendy globalnie (moze potrwac do 1h).
GUILD_ID=

# ----- Ekonomia (wartosci domyslne, mozna zostawic puste) -----
DAILY_AMOUNT=250
WORK_MIN=50
WORK_MAX=300
WORK_COOLDOWN=3600
DAILY_COOLDOWN=86400
START_BALANCE=0

# ----- Leveling / XP (wartosci domyslne, mozna zostawic puste) -----
XP_PER_MESSAGE_MIN=15
XP_PER_MESSAGE_MAX=25
XP_COOLDOWN=60
